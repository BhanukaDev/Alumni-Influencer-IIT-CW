# ─── Database ────────────────────────────────────────────────────────────────
# Path to the SQLite database file. Relative to apps/backend/.
DATABASE_URL="file:./dev.db"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Session ─────────────────────────────────────────────────────────────────
# Must be a random string of at least 32 characters. Used to sign session cookies.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace_with_a_random_32_plus_char_secret

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Include all frontends: alumni app (5173) and analytics dashboard (5174).
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# ─── Registration ─────────────────────────────────────────────────────────────
# Only email addresses ending in this domain can register.
ALLOWED_EMAIL_DOMAIN=iit.ac.lk

# ─── Email links ──────────────────────────────────────────────────────────────
# Base URL used when constructing verification and password reset links in emails.
FRONTEND_URL=http://localhost:5173

# ─── Bidding ──────────────────────────────────────────────────────────────────
# IANA timezone name for the winner selection cron job (runs at 18:00 local time).
BIDDING_TIMEZONE=Asia/Colombo
# Development only: run a test winner selection job N minutes after server start.
# Set to 0 or remove in production.
BIDDING_TEST_OFFSET_MINUTES=0

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
EMAIL_FROM=noreply@alumni.ac.uk
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
