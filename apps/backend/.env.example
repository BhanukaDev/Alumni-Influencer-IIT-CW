# SQLite file path, relative to apps/backend/
DATABASE_URL="file:./dev.db"

PORT=3000
NODE_ENV=development

# At least 32 random characters. Generate one with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace_with_a_random_32_plus_char_secret

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# Only emails ending in this domain can register
ALLOWED_EMAIL_DOMAIN=iit.ac.lk

# Used when building verification and password reset links in emails
FRONTEND_URL=http://localhost:5173

# IANA timezone for the 18:00 winner selection cron, e.g. Asia/Colombo
BIDDING_TIMEZONE=Asia/Colombo
# Dev only — run a test winner selection N minutes after server start. Remove in production.
BIDDING_TEST_OFFSET_MINUTES=0

EMAIL_FROM=noreply@alumni.ac.uk
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
