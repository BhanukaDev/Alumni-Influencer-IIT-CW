generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  ALUMNUS
  DEVELOPER
  ADMIN
}

enum BidStatus {
  PENDING
  WON
  LOST
  CANCELLED
}

model User {
  id                  Int               @id @default(autoincrement())
  email               String            @unique
  passwordHash        String
  role                Role              @default(ALUMNUS)
  isVerified          Boolean           @default(false)
  verifyToken         String?
  verifyTokenExpiry   DateTime?
  resetToken          String?
  resetTokenExpiry    DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  profile             Profile?
  bids                Bid[]
  appearanceRecords   AppearanceRecord[]
  apiKeys             ApiKey[]
}

model Profile {
  id          Int      @id @default(autoincrement())
  userId      Int      @unique
  bio         String?
  linkedinUrl String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  degrees      Degree[]
  certifications Certification[]
  licences     Licence[]
  courses      Course[]
  employments  Employment[]
}

model Degree {
  id             Int       @id @default(autoincrement())
  profileId      Int
  name           String
  university     String
  url            String?
  completionDate DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Certification {
  id             Int       @id @default(autoincrement())
  profileId      Int
  name           String
  issuer         String
  url            String?
  completionDate DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Licence {
  id             Int       @id @default(autoincrement())
  profileId      Int
  name           String
  body           String
  url            String?
  completionDate DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Course {
  id             Int       @id @default(autoincrement())
  profileId      Int
  name           String
  provider       String
  url            String?
  completionDate DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Employment {
  id        Int       @id @default(autoincrement())
  profileId Int
  company   String
  role      String
  startDate DateTime
  endDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Bid {
  id         Int       @id @default(autoincrement())
  userId     Int
  amount     Float
  windowDate DateTime
  status     BidStatus @default(PENDING)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AppearanceRecord {
  id         Int      @id @default(autoincrement())
  userId     Int
  month      Int
  year       Int
  count      Int      @default(0)
  eventBonus Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month, year])
}

model ApiKey {
  id          Int       @id @default(autoincrement())
  userId      Int
  keyHash     String    @unique
  label       String
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  usageLogs ApiKeyUsageLog[]
}

model ApiKeyUsageLog {
  id         Int      @id @default(autoincrement())
  apiKeyId   Int
  endpoint   String
  method     String
  accessedAt DateTime @default(now())

  apiKey ApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
}

model ProfileSubmission {
  id        Int      @id @default(autoincrement())
  fullName  String
  email     String
  createdAt DateTime @default(now())
}

model CampaignSubmission {
  id        Int      @id @default(autoincrement())
  topic     String
  budget    Float
  createdAt DateTime @default(now())
}
